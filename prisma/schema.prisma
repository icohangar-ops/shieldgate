generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Incident {
  id          String   @id @default(cuid())
  severity    String
  status      String   @default("open")
  title       String
  description String
  sourceIndex String
  assignedTeam String
  rawEvent    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userRole  String
  action    String
  resource  String   @default("")
  decision  String
  reason    String   @default("")
  timestamp DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  incidentId String
  role      String   @default("user")
  content   String
  timestamp DateTime @default(now())
}
